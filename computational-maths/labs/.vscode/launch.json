{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug with Manual Path and CWD",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/${input:typeExecutablePath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/${input:typeCwdPath}",
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ],
  "inputs": [
    {
      "id": "typeExecutablePath",
      "type": "promptString",
      "description": "1. Enter path to executable (e.g., bin/main.exe)",
      "default": "main.exe"
    },
    {
      "id": "typeCwdPath",
      "type": "promptString",
      "description": "2. Enter working directory (relative to workspace root)",
      "default": "."
    }
  ]
}